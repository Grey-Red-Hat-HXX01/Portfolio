<!doctype html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Gallery — HXX01</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=VT323&display=swap" rel="stylesheet">
<style>
:root { --accent: #00ffbb; --bg: #010101; --mono: "Share Tech Mono", monospace; }
*, *::before, *::after { box-sizing: border-box; margin: 0; }

body {
background: #010101;
color: #fff;
font-family: “Share Tech Mono”, “Courier New”, monospace;
padding: 30px 20px;
min-height: 100vh;
}

h1 {
font-family: “VT323”, monospace;
font-size: 2.8rem;
color: #00ffbb;
letter-spacing: 5px;
line-height: 1;
}

.sub {
color: #444;
font-size: 0.72rem;
letter-spacing: 2px;
margin: 6px 0 28px;
}

.grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
gap: 10px;
}

.media-item {
position: relative;
border-radius: 6px;
overflow: hidden;
border: 1px solid rgba(255,255,255,0.05);
background: #0a0a0a;
aspect-ratio: 1;
cursor: pointer;
transition: transform 0.2s ease, border-color 0.2s ease;
}
.media-item:hover { transform: scale(1.03); border-color: #00ffbb; }

.media-item img,
.media-item video {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
}

.media-item .label {
position: absolute;
bottom: 0; left: 0; right: 0;
background: rgba(0,0,0,0.7);
color: #888;
font-size: 0.6rem;
padding: 3px 6px;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}

.audio-item {
border: 1px solid rgba(255,255,255,0.05);
border-radius: 6px;
background: #0a0a0a;
padding: 12px;
margin-bottom: 8px;
display: flex;
align-items: center;
gap: 10px;
}
.audio-item span { color: #888; font-size: 0.75rem; flex: 1; }
.audio-item audio { flex: 2; min-width: 0; }

#audio-section h2 {
font-family: “Share Tech Mono”, monospace;
font-size: 0.72rem;
letter-spacing: 4px;
text-transform: uppercase;
color: #00ffbb;
margin: 28px 0 12px;
}

.empty { color: #333; font-size: 0.8rem; margin-top: 40px; }

/* Lightbox */
#lightbox {
display: none;
position: fixed;
inset: 0;
background: rgba(0,0,0,0.95);
z-index: 100;
align-items: center;
justify-content: center;
cursor: zoom-out;
}
#lightbox.open { display: flex; }
#lightbox img, #lightbox video {
max-width: 92vw;
max-height: 92vh;
object-fit: contain;
border-radius: 6px;
}

@media (max-width: 480px) {
.grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
}
</style>

</head>
<body>

<h1>GALLERY</h1>
<p class="sub">private · hxx01</p>

<div class="grid" id="grid"></div>
<div id="audio-section"></div>
<p class="empty" id="empty" style="display:none">no media found</p>

<div id="lightbox">
  <div id="lb-content"></div>
</div>

<script>
/*
  How this works:
  Caddy's "file_server browse" returns an HTML directory listing.
  We fetch /pictures/, parse out the file links, then render
  images/gifs as thumbnails, videos as muted previews, audio as players.
*/

var MEDIA_PATH = "/pictures/";
var IMG_EXTS   = ["jpg","jpeg","png","gif","webp","bmp","svg"];
var VID_EXTS   = ["mp4","webm","mov","mkv"];
var AUD_EXTS   = ["mp3","ogg","wav","flac","aac"];

var grid        = document.getElementById("grid");
var audioSec    = document.getElementById("audio-section");
var empty       = document.getElementById("empty");
var lightbox    = document.getElementById("lightbox");
var lbContent   = document.getElementById("lb-content");

function ext(name) {
  return name.split(".").pop().toLowerCase();
}

fetch(MEDIA_PATH)
  .then(function(r) { return r.text(); })
  .then(function(html) {
    var parser = new DOMParser();
    var doc    = parser.parseFromString(html, "text/html");
    var links  = doc.querySelectorAll("a[href]");
    var files  = [];

    links.forEach(function(a) {
      var href = a.getAttribute("href");
      // skip parent links and directories
      if (!href || href === "../" || href.endsWith("/") || href.startsWith("?")) return;
      var name = decodeURIComponent(href.split("/").pop());
      var e    = ext(name);
      if (
        IMG_EXTS.indexOf(e) !== -1 ||
        VID_EXTS.indexOf(e) !== -1 ||
        AUD_EXTS.indexOf(e) !== -1
      ) {
        files.push({ name: name, href: MEDIA_PATH + href, ext: e });
      }
    });

    if (files.length === 0) {
      empty.style.display = "block";
      return;
    }

    var hasAudio = false;
    var audioHTML = "<h2>Audio</h2>";

    files.forEach(function(f) {
      if (IMG_EXTS.indexOf(f.ext) !== -1) {
        // Image / GIF
        var item = document.createElement("div");
        item.className = "media-item";
        item.innerHTML =
          "<img src=\"" + f.href + "\" alt=\"" + f.name + "\" loading=\"lazy\">" +
          "<span class=\"label\">" + f.name + "</span>";
        item.addEventListener("click", function() { openLightbox("img", f.href); });
        grid.appendChild(item);

      } else if (VID_EXTS.indexOf(f.ext) !== -1) {
        // Video
        var item = document.createElement("div");
        item.className = "media-item";
        item.innerHTML =
          "<video src=\"" + f.href + "\" muted playsinline preload=\"metadata\"></video>" +
          "<span class=\"label\">" + f.name + "</span>";
        item.addEventListener("click", function() { openLightbox("video", f.href); });
        grid.appendChild(item);

      } else if (AUD_EXTS.indexOf(f.ext) !== -1) {
        // Audio
        hasAudio = true;
        audioHTML +=
          "<div class=\"audio-item\">" +
          "<span>" + f.name + "</span>" +
          "<audio controls src=\"" + f.href + "\"></audio>" +
          "</div>";
      }
    });

    if (hasAudio) {
      audioSec.innerHTML = audioHTML;
    }
  })
  .catch(function() {
    empty.style.display = "block";
    empty.textContent = "could not load media — check Caddy file_server browse is enabled";
  });

function openLightbox(type, src) {
  lbContent.innerHTML = type === "img"
    ? "<img src=\"" + src + "\" alt=\"\">"
    : "<video src=\"" + src + "\" controls autoplay style=\"max-width:92vw;max-height:92vh\"></video>";
  lightbox.classList.add("open");
}

lightbox.addEventListener("click", function(e) {
  if (e.target === lightbox) {
    lightbox.classList.remove("open");
    lbContent.innerHTML = "";
  }
});

document.addEventListener("keydown", function(e) {
  if (e.key === "Escape") {
    lightbox.classList.remove("open");
    lbContent.innerHTML = "";
  }
});
</script>

</body>
</html>